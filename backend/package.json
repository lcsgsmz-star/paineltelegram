{
  "name": "painel-telegram-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev": "npm run dev",
    "start:prod": "node dist/main.js",
    "postinstall": "node -e \"const fs=require('fs');const cp=require('child_process');const schema='../prisma/schema.prisma';if(fs.existsSync(schema)){cp.execFileSync('npx',['prisma','generate','--schema',schema],{stdio:'inherit'});}else{console.log('Skipping Prisma generate: schema not found.');}\"",
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "prisma:push": "prisma db push --schema ../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.0.0",
    "express-session": "^1.17.3",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "rate-limiter-flexible": "^2.3.5"
  },
  "devDependencies": {
    "@types/express-session": "^1.17.6",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "prisma": {
    "schema": "../prisma/schema.prisma"
  }
}
